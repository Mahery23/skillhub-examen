# ══════════════════════════════════════
# Application Laravel
# ══════════════════════════════════════
APP_NAME=SkillHub
APP_ENV=production

# APP_KEY à générer avec : php artisan key:generate --show
APP_KEY=

APP_DEBUG=false
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
BCRYPT_ROUNDS=12

# ══════════════════════════════════════
# Logs
# ══════════════════════════════════════
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ══════════════════════════════════════
# MySQL
# DB_HOST doit être "db" dans Docker, "127.0.0.1" en local
# ══════════════════════════════════════
DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=skillhub_db
DB_USERNAME=skillhub_user
DB_PASSWORD=change_me

MYSQL_ROOT_PASSWORD=change_me
MYSQL_DATABASE=skillhub_db
MYSQL_USER=skillhub_user
MYSQL_PASSWORD=change_me

# ══════════════════════════════════════
# MongoDB
# MONGODB_HOST doit être "mongodb" dans Docker, "127.0.0.1" en local
# ══════════════════════════════════════
MONGODB_URI=mongodb://mongo_user:change_me@mongodb:27017/skillhub_logs?authSource=admin
MONGODB_HOST=mongodb
MONGODB_PORT=27017
MONGODB_DATABASE=skillhub_logs
MONGODB_USERNAME=mongo_user
MONGODB_PASSWORD=change_me
MONGODB_AUTH_DATABASE=admin

# ══════════════════════════════════════
# JWT — PARTAGÉ entre Laravel et Spring Boot
# La même valeur doit être utilisée dans JWT_SECRET et APP_JWT_SECRET
# Générer avec : php artisan jwt:secret --show
# ══════════════════════════════════════
JWT_SECRET=change_me

# ══════════════════════════════════════
# Microservice Auth (Spring Boot)
# AUTH_SERVICE_URL doit être "http://auth-service:8080" dans Docker
# ══════════════════════════════════════
AUTH_SERVICE_URL=http://auth-service:8080

# JWT Spring Boot (même valeur que JWT_SECRET ci-dessus)
APP_JWT_SECRET=change_me

# Clé AES-GCM pour chiffrer les mots de passe (min 32 caractères)
APP_MASTER_KEY=change_me_with_32_chars_minimum!!

# Base de données du auth-service (base séparée dans le même MySQL)
AUTH_DB_URL=jdbc:mysql://db:3306/authdb?createDatabaseIfNotExist=true&useSSL=false&allowPublicKeyRetrieval=true
AUTH_DB_USERNAME=skillhub_user
AUTH_DB_PASSWORD=change_me

# ══════════════════════════════════════
# Session / Cache / Queue
# ══════════════════════════════════════
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=database

# ══════════════════════════════════════
# Redis
# ══════════════════════════════════════
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ══════════════════════════════════════
# Mail
# ══════════════════════════════════════
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# ══════════════════════════════════════
# Vite / Frontend React
# ══════════════════════════════════════
VITE_APP_NAME="${APP_NAME}"
VITE_API_BASE_URL=http://localhost:8000